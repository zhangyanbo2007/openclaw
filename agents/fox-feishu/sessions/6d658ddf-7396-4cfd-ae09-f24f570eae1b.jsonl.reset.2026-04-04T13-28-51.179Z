/node_modules/openclaw/docs/plugins/architecture.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/plugins/sdk-channel-plugins.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/plugins/sdk-setup.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/reference/templates/USER.dev.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/reference/templates/TOOLS.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/reference/templates/AGENTS.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/reference/test.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/reference/token-use.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/reference/AGENTS.default.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/reference/RELEASING.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/reference/memory-config.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/reference/transcript-hygiene.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/start/setup.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/start/onboarding.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/platforms/mac/voice-overlay.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/platforms/mac/bundled-gateway.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/platforms/mac/remote.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/platforms/mac/webchat.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/platforms/mac/dev-setup.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/platforms/mac/icon.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/platforms/mac/voicewake.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/platforms/linux.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/platforms/macos.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/vps.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/web/tui.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/web/webchat.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/web/index.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/security.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/devices.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/message.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/hooks.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/onboard.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/index.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/qr.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/gateway.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/update.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/acp.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/plugins.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/sandbox.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/cli/approvals.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/pi.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/help/faq.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/help/testing.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/help/environment.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/help/debugging.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/diagnostics/flags.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/logging.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/install/docker-vm-runtime.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/install/docker.md\n/home/zhangyanbo/.npm-global/lib/node_modules/openclaw/docs/install/development-ch