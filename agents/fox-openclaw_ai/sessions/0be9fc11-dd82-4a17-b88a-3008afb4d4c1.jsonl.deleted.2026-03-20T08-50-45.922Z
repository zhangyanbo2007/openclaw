\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            text-align: center;\n        }\n        \n        .section-slide {\n            background: white;\n            box-shadow: 0 4px 20px rgba(0,0,0,0.1);\n            margin: 20px;\n            border-radius: 10px;\n        }\n        \n        h1 {\n            font-size: 3.5em;\n            margin-bottom: 20px;\n            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);\n        }\n        \n        h2 {\n            font-size: 2.5em;\n            color: #667eea;\n            margin-bottom: 30px;\n            padding-bottom: 15px;\n            border-bottom: 3px solid #667eea;\n        }\n        \n        h3 {\n            font-size: 1.8em;\n            color: #764ba2;\n            margin: 25px 0 15px 0;\n        }\n        \n        .subtitle {\n            font-size: 1.8em;\n            margin-bottom: 30px;\n            opacity: 0.9;\n        }\n        \n        .meta-info {\n            font-size: 1.2em;\n            margin-top: 50px;\n            opacity: 0.8;\n        }\n        \n        .content-section {\n            margin-bottom: 30px;\n            padding-left: 20px;\n        }\n        \n        .algorithm-box {\n            background: #f8f9fa;\n            border-left: 4px solid #667eea;\n            padding: 20px;\n            margin: 15px 0;\n            border-radius: 0 8px 8px 0;\n        }\n        \n        .algorithm-title {\n            font-weight: bold;\n            color: #667eea;\n            margin-bottom: 10px;\n        }\n        \n        .code-block {\n            background: #2d3748;\n            color: #e2e8f0;\n            padding: 15px;\n            border-radius: 8px;\n            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;\n            margin: 15px 0;\n            overflow-x: auto;\n            white-space: pre;\n            font-size: 0.9em;\n            line-height: 1.5;\n        }\n        \n        .comparison-table {\n            width: 100%;\n            border-collapse: collapse;\n            margin: 20px 0;\n        }\n        \n        .comparison-table th, .comparison-table td {\n            border: 1px solid #ddd;\n            padding: 12px;\n            text-align: left;\n        }\n        \n        .comparison-table th {\n            background: #667eea;\n            color: white;\n        }\n        \n        .comparison-table tr:nth-child(even) {\n            background: #f8f9fa;\n        }\n        \n        .feature-list {\n            list-style-type: none;\n            padding-left: 0;\n        }\n        \n        .feature-list li {\n            padding: 10px 0;\n            border-bottom: 1px solid #eee;\n            position: relative;\n            padding-left: 25px;\n        }\n        \n        .feature-list li:before {\n            content: \"▸\";\n            position: absolute;\n            left: 0;\n            color: #667eea;\n            font-weight: bold;\n        }\n        \n        .highlight {\n            background: linear-gradient(120deg, #a1c4fd 0%, #c2e9fb 100%);\n            padding: 3px 8px;\n            border-radius: 4px;\n            font-weight: bold;\n        }\n        \n        .diagram-container {\n            text-align: center;\n            margin: 30px 0;\n            padding: 20px;\n            background: #f0f4f8;\n            border-radius: 10px;\n        }\n        \n        .diagram-title {\n            font-size: 1.3em;\n            color: #667eea;\n            margin-bottom: 15px;\n            font-weight: bold;\n        }\n        \n        .nav-hint {\n            position: fixed;\n            bottom: 20px;\n            right: 20px;\n            background: rgba(0,0,0,0.7);\n            color: white;\n            padding: 10px 15px;\n            border-radius: 5px;\n            font-size: 0.9em;\n        }\n        \n        .progress-bar {\n            position: fixed;\n            top: 0;\n            left: 0;\n            height: 4px;\n            background: linear-gradient(90deg, #667eea, #764ba2);\n            transition: width 0.3s ease;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"progress-bar\" id=\"progressBar\"></div>\n    \n    <!-- 封面页 -->\n    <div class=\"slide cover-slide\" id=\"slide1\">\n        <h1>OpenClaw AI算法架构深度解读</h1>\n        <p class=\"subtitle\">个人AI助手的算法设计与实现</p>\n        <div class=\"meta-info\">\n            <p>📝 包含完整图例版</p>\n            <p>日期：2026年3月</p>\n        </div>\n    </div>\n\n    <!-- 目录页 -->\n    <div class=\"slide section-slide\" id=\"slide2\">\n        <h2>目录</h2>\n        <div class=\"content-section\">\n            <ul class=\"feature-list\" style=\"font-size: 1.2em;\">\n                <li>第一部分：OpenClaw整体架构概览</li>\n                <li>第二部分：核心控制层Pi的AI算法</li>\n                <li>第三部分：推理引擎算法</li>\n                <li>第四部分：工具调用与决策算法</li>\n                <li>第五部分：记忆系统算法</li>\n                <li>第六部分：技能系统算法</li>\n                <li>第七部分：总结与展望</li>\n            </ul>\n        </div>\n    </div>\n\n    <!-- 第一部分：OpenClaw整体架构概览 -->\n    <div class=\"slide section-slide\" id=\"slide3\">\n        <h2>第一部分：OpenClaw整体架构概览</h2>\n        \n        <div class=\"content-section\">\n            <h3>1.1 系统架构分层图</h3>\n            <div class=\"diagram-container\">\n                <div class=\"diagram-title\">📊 系统架构分层图</div>\n                <div class=\"code-block\">\n┌─────────────────────────────────┐\n│        应用层                   │\n│  - 用户交互界面                │\n│  - 技能调用                    │\n└─────────────────────────────────┘\n┌─────────────────────────────────┐\n│        控制层 (Pi Agent)        │\n│  - 推理引擎                    │\n│  - 工具调用管理                │\n│  - 状态管理                    │\n└─────────────────────────────────┘\n┌─────────────────────────────────┐\n│        核心服务层               │\n│  - 记忆系统                    │\n│  - 技能系统                    │\n│  - 会话管理                    │\n└─────────────────────────────────┘\n┌─────────────────────────────────┐\n│        基础设施层               │\n│  - 模型接口                    │\n│  - 工具接口                    │\n│  - 存储接口                    │\n└─────────────────────────────────┘\n                </div>\n            </div>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">分层架构算法设计</div>\n                <ul class=\"feature-list\">\n                    <li><strong>应用层算法</strong>：负责用户输入解析和输出渲染，实现自然语言到工具调用的转换</li>\n                    <li><strong>控制层算法</strong>：核心决策单元，使用极简提示词压缩技术，实现高效推理</li>\n                    <li><strong>服务层算法</strong>：提供状态持久化、技能管理和会话连续性的基础服务</li>\n                    <li><strong>基础设施层算法</strong>：抽象底层实现，提供统一的接口供上层调用</li>\n                </ul>\n            </div>\n        </div>\n    </div>\n\n    <!-- 第二部分：核心控制层Pi的AI算法 -->\n    <div class=\"slide section-slide\" id=\"slide4\">\n        <h2>第二部分：核心控制层Pi的AI算法</h2>\n        \n        <div class=\"content-section\">\n            <h3>2.1 提示词压缩算法</h3>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">传统方案 vs Pi方案对比</div>\n                <table class=\"comparison-table\">\n                    <tr>\n                        <th>方案</th>\n                        <th>提示词长度</th>\n                        <th>token消耗</th>\n                        <th>推理效率</th>\n                    </tr>\n                    <tr>\n                        <td>传统方案(Claude Code)</td>\n                        <td>10,000+ tokens</td>\n                        <td>高</td>\n                        <td>中等</td>\n                    </tr>\n                    <tr>\n                        <td>Pi方案</td>\n                        <td><span class=\"highlight\">&lt; 1000 tokens</span></td>\n                        <td>极低</td>\n                        <td>高</td>\n                    </tr>\n                </table>\n            </div>\n        </div>\n        \n        <div class=\"content-section\">\n            <h3>2.2 状态管理流程图</h3>\n            <div class=\"diagram-container\">\n                <div class=\"diagram-title\">📊 状态管理流程图</div>\n                <div class=\"code-block\">\n    用户输入\n        ↓\n    生成推理过程\n        ↓\n    决策是否调用工具 → 是 → 执行工具调用\n        ↓                         ↓\n    生成响应 ← 整合结果 ← 执行完成\n                </div>\n            </div>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">状态管理算法核心思想</div>\n                <p><strong>核心思想</strong>：状态序列化到磁盘</p>\n                <ul class=\"feature-list\">\n                    <li><strong>避免上下文衰减</strong>：状态持久化存储，不受对话轮次限制</li>\n                    <li><strong>支持断点续传</strong>：从任意位置继续执行，无需重新开始</li>\n                    <li><strong>允许全新上下文继续</strong>：不受历史状态限制，每次都是全新开始</li>\n                </ul>\n            </div>\n        </div>\n        \n        <div class=\"content-section\">\n            <h3>2.3 推理循环流程图</h3>\n            <div class=\"diagram-container\">\n                <div class=\"diagram-title\">📊 推理循环流程图</div>\n                <div class=\"code-block\">\n┌─────────────────────────────────────────┐\n│           标准推理循环                  │\n├─────────────────────────────────────────┤\n│ 1. 接收用户输入                         │\n│ 2. 生成推理过程                         │\n│ 3. 决策是否调用工具                     │\n│ 4. 执行工具调用                         │\n│ 5. 整合结果                             │\n│ 6. 生成响应                             │\n└─────────────────────────────────────────┘\n                </div>\n            </div>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">Pi的优化算法</div>\n                <ul class=\"feature-list\">\n                    <li><strong>极简提示词减少干扰</strong>：减少上下文中的噪音信息</li>\n                    <li><strong>状态序列化保持一致性</strong>：确保每次推理基于相同的状态</li>\n                    <li><strong>完全可观测的推理过程</strong>：所有中间步骤对用户可见</li>\n                </ul>\n            </div>\n        </div>\n    </div>\n\n    <!-- 第三部分：推理引擎算法 -->\n    <div class=\"slide section-slide\" id=\"slide5\">\n        <h2>第三部分：推理引擎算法</h2>\n        \n        <div class=\"content-section\">\n            <h3>3.1 意图理解算法</h3>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">Pi的意图理解方法</div>\n                <p><strong>直接利用LLM的语义理解能力</strong>：不依赖复杂的NLP预处理，直接使用LLM的理解能力</p>\n                <p><strong>极简提示词引导</strong>：用最少的指令引导模型理解用户意图</p>\n                <p><strong>上下文驱动的理解</strong>：结合对话历史和当前状态，准确理解用户需求</p>\n            </div>\n        </div>\n        \n        <div class=\"content-section\">\n            <h3>3.2 计划生成算法</h3>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">Pi的计划生成方法</div>\n                <ol>\n                    <li><strong>分析任务需求</strong>：理解用户要做什么，识别关键目标</li>\n                    <li><strong>探索代码库现状</strong>：使用/tree命令了解当前代码结构和状态</li>\n                    <li><strong>生成执行计划</strong>：制定具体的执行步骤和时间安排</li>\n                    <li><strong>计划序列化到PLAN.md</strong>：保存计划供后续使用和跟踪</li>\n                </ol>\n            </div>\n        </div>\n    </div>\n\n    <!-- 第四部分：工具调用与决策算法 -->\n    <div class=\"slide section-slide\" id=\"slide6\">\n        <h2>第四部分：工具调用与决策算法</h2>\n        \n        <div class=\"content-section\">\n            <h3>4.1 工具调用决策流程图</h3>\n            <div class=\"diagram-container\">\n                <div class=\"diagram-title\">📊 工具调用决策流程图</div>\n                <div class=\"code-block\">\n    开始\n      ↓\n    分析任务需求\n      ↓\n    评估可用工具\n      ↓\n    决策是否调用工具 → 否 → 直接执行\n      ↓ 是\n    选择具体工具\n      ↓\n    调用工具执行\n      ↓\n    结束\n                </div>\n            </div>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">Pi的决策算法流程</div>\n                <ol>\n                    <li><strong>分析任务需求</strong>：理解当前任务需要什么操作和输出</li>\n                    <li><strong>评估可用工具</strong>：检查有哪些工具可以使用，评估工具适用性</li>\n                    <li><strong>决策是否调用工具</strong>：判断是否需要工具辅助完成任务</li>\n                    <li><strong>选择具体工具</strong>：选择最合适的工具，考虑效率和准确性</li>\n                </ol>\n            </div>\n        </div>\n        \n        <div class=\"content-section\">\n            <h3>4.2 工具集设计</h3>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">Pi的4个核心工具</div>\n                <table class=\"comparison-table\">\n                    <tr>\n                        <th>工具</th>\n                        <th>功能</th>\n                        <th>设计原则</th>\n                    </tr>\n                    <tr>\n                        <td>read</td>\n                        <td>读取文件内容</td>\n                        <td>获取文件信息的基础工具</td>\n                    </tr>\n                    <tr>\n                        <td>write</td>\n                        <td>创建或覆盖文件</td>\n                        <td>文件创建和写入的核心工具</td>\n                    </tr>\n                    <tr>\n                        <td>edit</td>\n                        <td>修改文件内容</td>\n                        <td>精确编辑文件的工具</td>\n                    </tr>\n                    <tr>\n                        <td>bash</td>\n                        <td>执行系统命令</td>\n                        <td>运行外部程序和命令的工具</td>\n                    </tr>\n                </table>\n            </div>\n        </div>\n    </div>\n\n    <!-- 第五部分：记忆系统算法 -->\n    <div class=\"slide section-slide\" id=\"slide7\">\n        <h2>第五部分：记忆系统算法</h2>\n        \n        <div class=\"content-section\">\n            <h3>5.1 记忆存储算法</h3>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">Pi的记忆存储观点</div>\n                <p><strong>代码库就是source of truth</strong>：代码是最终的真相，不需要额外的记忆系统</p>\n                <p><strong>不需要额外的记忆系统</strong>：避免维护额外的信息层，减少复杂度</p>\n                <p><strong>让agent探索代码库当前状态</strong>：每次从零开始探索，确保信息的准确性</p>\n            </div>\n        </div>\n        \n        <div class=\"content-section\">\n            <h3>5.2 会话连续性算法</h3>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">Pi的解决方案算法</div>\n                <ol>\n                    <li><strong>会话结束时生成摘要</strong>：总结当前工作状态和进度</li>\n                    <li><strong>新会话加载摘要</strong>：恢复之前的工作状态</li>\n                    <li><strong>基于摘要继续工作</strong>：从断点继续执行，无需重新开始</li>\n                </ol>\n            </div>\n        </div>\n    </div>\n\n    <!-- 第六部分：技能系统算法 -->\n    <div class=\"slide section-slide\" id=\"slide8\">\n        <h2>第六部分：技能系统算法</h2>\n        \n        <div class=\"content-section\">\n            <h3>6.1 技能扩展流程图</h3>\n            <div class=\"diagram-container\">\n                <div class=\"diagram-title\">📊 技能扩展流程图</div>\n                <div class=\"code-block\">\n    ┌─────────────────────────────────────────┐\n    │        添加新技能的流程                 │\n    ├─────────────────────────────────────────┤\n    │                                         │\n    │  1. 编写CLI工具                         │\n    │     ↓                                   │\n    │  2. 编写README文档                      │\n    │     ↓                                   │\n    │  3. 放入技能目录                        │\n    │     ↓                                   │\n    │  4. agent按需加载                       │\n    │     ↓                                   │\n    │  5. 技能调用执行                        │\n    │                                         │\n    └─────────────────────────────────────────┘\n                </div>\n            </div>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">Pi的技能扩展方法</div>\n                <ol>\n                    <li><strong>编写CLI工具</strong>：用任意语言编写可执行程序</li>\n                    <li><strong>编写README文档</strong>：描述技能功能和用法</li>\n                    <li><strong>放入技能目录</strong>：将技能文件放到指定目录</li>\n                    <li><strong>agent按需加载</strong>：agent需要时读取技能文档</li>\n                </ol>\n            </div>\n        </div>\n        \n        <div class=\"content-section\">\n            <h3>6.2 技能发现算法</h3>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">Pi的技能发现方法</div>\n                <p><strong>技能以CLI工具形式存在</strong>：每个技能是一个可执行的命令行程序</p>\n                <p><strong>每个技能有README文档</strong>：描述技能功能、用法和接口</p>\n                <p><strong>agent按需读取技能文档</strong>：需要时才学习技能用法</p>\n            </div>\n        </div>\n    </div>\n\n    <!-- 第七部分：总结与展望 -->\n    <div class=\"slide section-slide\" id=\"slide9\">\n        <h2>第七部分：总结与展望</h2>\n        \n        <div class=\"content-section\">\n            <h3>7.1 核心算法创新</h3>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">五大核心算法创新</div>\n                <ol>\n                    <li><span class=\"highlight\">极简提示词设计</span>（&lt; 1000 tokens）：大幅减少上下文消耗</li>\n                    <li><span class=\"highlight\">状态序列化管理</span>（解决上下文衰减）：支持断点续传</li>\n                    <li><span class=\"highlight\">按需工具加载</span>（大幅降低token消耗）：相比MCP的1/60</li>\n                    <li><span class=\"highlight\">完全可观测推理</span>（避免黑箱操作）：所有过程可见</li>\n                    <li><span class=\"highlight\">探索式上下文收集</span>（基于当前状态工作）：避免过时信息</li>\n                </ol>\n            </div>\n        </div>\n        \n        <div class=\"content-section\">\n            <h3>7.2 性能指标</h3>\n            \n            <div class=\"algorithm-box\">\n                <div class=\"algorithm-title\">关键性能指标</div>\n                <table class=\"comparison-table\">\n                    <tr>\n                        <th>指标</th>\n                        <th>数值</th>\n                        <th>说明</th>\n                    </tr>\n                    <tr>\n                        <td>系统提示词</td>\n                        <td><span class=\"highlight\">&lt; 1000 tokens</span></td>\n                        <td>极简设计，大幅减少上下文消耗</td>\n                    </tr>\n                    <tr>\n                        <td>工具消耗</td>\n                        <td><span class=\"highlight\">225 tokens</span></td>\n                        <td>相比MCP的1/60，效率提升显著</td>\n                    </tr>\n                    <tr>\n                        <td>GitHub stars</td>\n                        <td><span class=\"highlight\">24,000+</span></td>\n                        <td>社区认可，广泛采用</td>\n                    </tr>\n                    <tr>\n                        <td>Terminal Bench排名</td>\n                        <td><span class=\"highlight\">前五</span></td>\n                        <td>性能验证，业界领先</td>\n                    </tr>\n                </table>\n            </div>\n        </div>\n    </div>\n\n    <!-- 结束页 -->\n    <div class=\"slide cover-slide\" id=\"slide10\">\n        <h1>感谢聆听！</h1>\n        <p class=\"subtitle\">OpenClaw AI算法架构深度解读</p>\n        <div class=\"meta-info\">\n            <p>🎉 欢迎交流与讨论</p>\n            <p>📧 OpenClaw - 个人AI助手的未来</p>\n        </div>\n    </div>\n\n    <!-- 导航提示 -->\n    <div class=\"nav-hint\">\n        ⬅️ ➡️ 方向键导航 | 点击左右切换\n    </div>\n\n    <script>\n        // 幻灯片导航系统\n        let currentSlide = 1;\n        const totalSlides = 10;\n        \n        function showSlide(slideNumber) {\n            // 隐藏所有幻灯片\n            for (let i = 1; i <= totalSlides; i++) {\n                const slide = document.getElementById('slide' + i);\n                if (slide) {\n                    slide.style.display = 'none';\n                }\n            }\n            \n            // 显示当前幻灯片\n            const currentSlideElement = document.getElementById('slide' + slideNumber);\n            if (currentSlideElement) {\n                currentSlideElement.style.display = 'flex';\n            }\n            \n            // 更新进度条\n            const progressBar = document.getElementById('progressBar');\n            if (progressBar) {\n                progressBar.style.width = (slideNumber / totalSlides * 100) + '%';\n            }\n            \n            currentSlide = slideNumber;\n        }\n        \n        // 键盘导航\n        document.addEventListener('keydown', (e) => {\n            if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {\n                if (currentSlide < totalSlides) {\n                    showSlide(currentSlide + 1);\n                }\n            } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {\n                if (currentSlide > 1) {\n                    showSlide(currentSlide - 1);\n                }\n            }\n        });\n        \n        // 点击导航\n        document.addEventListener('click', (e) => {\n            if (e.clientX > window.innerWidth / 2) {\n                if (currentSlide < totalSlides) {\n                    showSlide(currentSlide + 1);\n                }\n            } else {\n                if (currentSlide > 1) {\n                    showSlide(currentSlide - 1);\n                }\n            }\n        });\n        \n        // 初始化显示第一张幻灯片\n        showSlide(1);\n    </script>\n</body>\n</html>"}}],"api":"openai-completions","provider":"openrouter","model":"xiaomi/mimo-v2-flash","usage":{"input":766,"output":6655,"cacheRead":27710,"cacheWrite":0,"totalTokens":35131,"cost":{"input":0.00006894,"output":0.00192995,"cacheRead":0.00124695,"cacheWrite":0,"total":0.00324584}},"stopReason":"toolUse","timestamp":1773993033184}}
