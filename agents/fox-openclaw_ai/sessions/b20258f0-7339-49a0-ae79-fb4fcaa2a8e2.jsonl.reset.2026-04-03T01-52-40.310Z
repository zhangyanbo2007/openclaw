\",\n        \"model\": \"text-embedding-v3\"\n      },\n      \"compaction\": {"}],"file":"~/.openclaw/openclaw.json"}}],"api":"anthropic-messages","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-plus","usage":{"input":6,"output":684,"cacheRead":88079,"cacheWrite":4907,"totalTokens":93676,"cost":{"input":6.6e-7,"output":0.00019152,"cacheRead":0,"cacheWrite":0,"total":0.00019218000000000002}},"stopReason":"toolUse","timestamp":1775034492988,"responseId":"msg_043e65ff-4013-4d6f-9404-c45b846fa86e"}}
