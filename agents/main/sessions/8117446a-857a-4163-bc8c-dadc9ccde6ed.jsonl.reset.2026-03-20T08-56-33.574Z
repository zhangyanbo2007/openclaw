{"type":"message","id":"22943e56","parentId":"ffefc4a5","timestamp":"2026-03-20T08:47:28.992Z","message":{"role":"toolResult","toolCallId":"call_6f34178a23d64765857df63a","toolName":"web_search","content":[{"type":"text","text":"{\n  \"query\": \"OpenRouter API pricing models 2025 2026 cost per million tokens\",\n  \"provider\": \"brave\",\n  \"count\": 5,\n  \"tookMs\": 3334,\n  \"externalContent\": {\n    \"untrusted\": true,\n    \"source\": \"web_search\",\n    \"provider\": \"brave\",\n    \"wrapped\": true\n  },\n  \"results\": [\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"10c769ac56ca579d\\\">>>\\nSource: Web Search\\n---\\nPricing | OpenRouter\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"10c769ac56ca579d\\\">>>\",\n      \"url\": \"https://openrouter.ai/pricing\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"92345edf04111f2f\\\">>>\\nSource: Web Search\\n---\\nNo. <strong>Pricing is per token regardless of streaming</strong>.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"92345edf04111f2f\\\">>>\",\n      \"siteName\": \"openrouter.ai\"\n    },\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"8f8425c4b6fb37b7\\\">>>\\nSource: Web Search\\n---\\nModels | OpenRouter\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"8f8425c4b6fb37b7\\\">>>\",\n      \"url\": \"https://openrouter.ai/models\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"ae0a7b286b669ef3\\\">>>\\nSource: Web Search\\n---\\nBrowse models on OpenRouter\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"ae0a7b286b669ef3\\\">>>\",\n      \"siteName\": \"openrouter.ai\"\n    },\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"d29e6df1f55a1984\\\">>>\\nSource: Web Search\\n---\\nOpenRouter Models | Access 400+ AI Models Through One API | OpenRouter | Documentation\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"d29e6df1f55a1984\\\">>>\",\n      \"url\": \"https://openrouter.ai/docs/guides/overview/models\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"e22b8d79523ee452\\\">>>\\nSource: Web Search\\n---\\nSome models break up text into chunks of multiple characters (GPT, Claude, Llama, etc), while others tokenize by character (PaLM). This means that token counts (and therefore costs) will vary between models, even when inputs and outputs are the same. Costs are displayed and billed according to the tokenizer for the model in use.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"e22b8d79523ee452\\\">>>\",\n      \"siteName\": \"openrouter.ai\"\n    },\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"9b7b7089c7a62f06\\\">>>\\nSource: Web Search\\n---\\nOpenRouter Models Pricing Calculator | Compare Model Costs Instantly\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"9b7b7089c7a62f06\\\">>>\",\n      \"url\": \"https://invertedstone.com/calculators/openrouter-pricing\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"d0f6b18c7633c044\\\">>>\\nSource: Web Search\\n---\\nPrices shown are derived from the OpenRouter Models API and saved locally during development. These are per-token rates multiplied by your provided token counts. Actual billing may vary depending on factors like prompt caching, batching, reasoning, web search, or tool usage.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"d0f6b18c7633c044\\\">>>\",\n      \"siteName\": \"invertedstone.com\"\n    },\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"1ba160e4618b1f43\\\">>>\\nSource: Web Search\\n---\\nOpenRouter Pricing Calculator & Cost Guide (Mar 2026)\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"1ba160e4618b1f43\\\">>>\",\n      \"url\": \"https://costgoat.com/pricing/openrouter\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"e9468782f73bb789\\\">>>\\nSource: Web Search\\n---\\nModels like DeepSeek R1, Llama 3.3 70B, and Gemma 3 are available at zero cost. Only switch to paid models when you need higher quality or throughput. ... Don&#x27;t use Opus ($<strong>5/$25 per 1M tokens</strong>) for tasks that Haiku ($1/$5) handles well.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"e9468782f73bb789\\\">>>\",\n      \"published\": \"1 day ago\",\n      \"siteName\": \"costgoat.com\"\n    }\n  ]\n}"}],"details":{"query":"OpenRouter API pricing models 2025 2026 cost per million tokens","provider":"brave","count":5,"tookMs":3334,"externalContent":{"untrusted":true,"source":"web_search","provider":"brave","wrapped":true},"results":[{"title":"\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\"10c769ac56ca579d\">>>\nSource: Web Search\n---\nPricing | OpenRouter\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\"10c769ac56ca579d\">>>","url":"https://openrouter.ai/pricing","description":"\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\"92345edf04111f2f\">>>\nSource: Web Search\n---\nNo. <strong>Pricing is per token regardless of streaming</strong>.\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\"92345edf04111f2f\">>>","siteName":"openrouter.ai"},{"title":"\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\"8f8425c4b6fb37b7\">>>\nSource: Web Search\n---\nModels | OpenRouter\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\"8f8425c4b6fb37b7\">>>","url":"https://openrouter.ai/models","description":"\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\"ae0a7b286b669ef3\">>>\nSource: Web Search\n---\nBrowse models on OpenRouter\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\"ae0a7b286b669ef3\">>>","siteName":"openrouter.ai"},{"title":"\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\"d29e6df1f55a1984\">>>\nSource: Web Search\n---\nOpenRouter Models | Access 400+ AI Models Through One API | OpenRouter | Documentation\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\"d29e6df1f55a1984\">>>","url":"https://openrouter.ai/docs/guides/overview/models","description":"\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\"e22b8d79523ee452\">>>\nSource: Web Search\n---\nSome models break up text into chunks of multiple characters (GPT, Claude, Llama, etc), while others tokenize by character (PaLM). This means that token counts (and therefore costs) will vary between models, even